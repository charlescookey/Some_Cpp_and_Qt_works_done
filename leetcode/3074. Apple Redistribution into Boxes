class Solution {
public:
    int minimumBoxes(vector<int>& apple, vector<int>& capacity) {
        std::sort(capacity.rbegin() , capacity.rend());
        int sum = std::accumulate(apple.begin() , apple.end() , 0);
        int ans =0;
        for(int i : capacity){
            sum -= i;
            ans++;
            if(sum <= 0)break;
        }
        return ans;
    }
};
